# Normalize line endings: store text as LF in the repo, convert on checkout.
# Keeps diffs clean across Linux (backend deploy), macOS, and Windows.
* text=auto eol=lf

# Windows scripts must stay CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Explicit text types
*.py    text
*.ts    text
*.tsx   text
*.js    text
*.jsx   text
*.json  text
*.dart  text
*.md    text
*.css   text
*.html  text
*.yml   text
*.yaml  text
*.toml  text
*.ini   text
*.mako  text

# Binary assets (never normalize or diff as text)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.jar   binary
*.keystore binary
*.db    binary
*.sqlite3 binary
