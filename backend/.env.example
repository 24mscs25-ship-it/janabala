# Copy to .env and adjust. Never commit the real .env.

# Set to False in production. When True, send-otp returns the OTP in the
# response for local testing (no SMS provider needed).
DEBUG=True

# SQLite by default so the app runs with zero external services.
# For production use Postgres, e.g.:
# DATABASE_URL=postgresql+psycopg2://janabala:password@localhost:5432/janabala
DATABASE_URL=sqlite:///./janabala.db

# CHANGE THIS in production. Used to sign JWTs.
SECRET_KEY=change-me-in-production

# JWT lifetime (minutes). Default 7 days.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of allowed origins. Lock this down in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# OTP settings
OTP_LENGTH=6
OTP_EXPIRE_SECONDS=300
# Min seconds between OTP resends for the same phone.
OTP_RESEND_COOLDOWN_SECONDS=60
# Wrong verify attempts allowed before the OTP locks (request a new one).
OTP_MAX_ATTEMPTS=5

# SMS provider. Leave SMS_API_KEY empty to use the console fallback (in DEBUG
# the OTP is also echoed in the send-otp response, so no real SMS is needed).
# Set SMS_API_KEY (and SMS_TEMPLATE_ID) to deliver real OTPs via MSG91.
SMS_PROVIDER=msg91
SMS_API_KEY=
# MSG91 approved OTP template id (DLT). Required for real delivery.
SMS_TEMPLATE_ID=
SMS_SENDER_ID=JANBAL
SMS_DEFAULT_COUNTRY_CODE=91
SMS_BASE_URL=https://control.msg91.com/api/v5
SMS_TIMEOUT_SECONDS=10

# Uploads (local-disk storage for issue photos).
UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=5242880
UPLOAD_URL_PREFIX=/media
