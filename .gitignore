# Auto-generated sensible .gitignore

# Secrets — never commit
.env
.env.*
!.env.example
*.key
*.pem
tokens.json

# Logs & OS
*.log
logs/
.DS_Store
Thumbs.db

# Quarantine folder (kept local)
.bin/

# Tooling output
graphify-out/
.playwright-mcp/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/
.venv/
venv/

# Local SQLite databases (dev/test)
*.db
*.sqlite3

# Uploaded media (local-disk storage)
backend/uploads/
uploads/
